<body>

<header>
  <span class="header-title">❯ changes review</span>
  <span class="header-hints">
    <span class="hint-key">⌘←→</span> hunk &nbsp;·&nbsp;
    <span class="hint-key">⌘↑↓</span> file &nbsp;·&nbsp;
    <span class="hint-key">⌘↵</span> submit
  </span>
  <span id="comment-summary"></span>
  <button id="submit-btn">Submit</button>
</header>

<div class="layout">
  <nav id="file-list">
    <div class="list-heading">Files</div>
  </nav>
  <section id="diff-panel">
    <p id="empty">Select a file from the list.</p>
  </section>
</div>

<div id="done-overlay">
  <p>✓ Review submitted</p>
  <small>Closing…</small>
</div>

<script>
const FILES = __DIFF_DATA__;

const STATUS_ICON  = { added: '+', deleted: '−', modified: '±', renamed: '~', unknown: '?' };
const STATUS_CLASS = { added: 's-added', deleted: 's-deleted', modified: 's-modified', renamed: 's-renamed' };

const state = { file: 0, hunk: 0, comments: {} };

const esc = s => s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
const key = (fi, hi) => \`\${fi}:\${hi}\`;

function totalComments() {
  return Object.values(state.comments).filter(v => v.trim()).length;
}

function fileCommentCount(fi) {
  return FILES[fi].hunks.reduce((n, _, hi) =>
    n + ((state.comments[key(fi, hi)] || '').trim() ? 1 : 0), 0);
}

// ── File list ──────────────────────────────────────────────────────────────
function renderFileList() {
  const nav = document.getElementById('file-list');
  const heading = nav.querySelector('.list-heading');
  nav.innerHTML = '';
  nav.appendChild(heading);

  FILES.forEach((f, fi) => {
    const count = fileCommentCount(fi);
    const el = document.createElement('div');
    el.className = 'file-item' + (fi === state.file ? ' active' : '');
    el.innerHTML =
      \`<span class="file-status \${STATUS_CLASS[f.status] || ''}">\${STATUS_ICON[f.status] || '?'}</span>\` +
      \`<span class="file-name" title="\${esc(f.path)}">\${esc(f.path.split('/').pop())}</span>\` +
      (count ? \`<span class="file-badge">\${count}</span>\` : '');
    el.addEventListener('click', () => { state.file = fi; state.hunk = 0; renderAll(); });
    nav.appendChild(el);
  });
}

// ── Diff panel ─────────────────────────────────────────────────────────────
function renderDiffPanel() {
  const panel = document.getElementById('diff-panel');
  if (!FILES.length) { panel.innerHTML = '<p id="empty">No changes found.</p>'; return; }

  const fi   = state.file;
  const f    = FILES[fi];
  const hi   = state.hunk;
  const hunk = f.hunks[hi];
  const k    = key(fi, hi);
  const cur  = state.comments[k] || '';

  let html = \`<div id="hunk-bar">
    <span id="file-title">\${esc(f.path)}</span>
    <span id="hunk-counter">\${f.hunks.length ? \`\${hi + 1} / \${f.hunks.length}\` : 'no hunks'}</span>
    <button class="hunk-btn" id="btn-prev" \${hi === 0 ? 'disabled' : ''}>← prev</button>
    <button class="hunk-btn" id="btn-next" \${hi >= f.hunks.length - 1 ? 'disabled' : ''}>next →</button>
  </div>\`;

  if (!hunk) {
    panel.innerHTML = html + '<p style="color:var(--dim)">No hunks in this file.</p>';
    return;
  }

  html += \`<div class="hunk-header-line">\${esc(hunk.header)}</div>\`;

  const beforeContent = hunk.isPureAddition
    ? '<span class="empty-code">(pure addition)</span>'
    : esc(hunk.before) || '<span class="empty-code">(empty)</span>';
  const afterContent = hunk.isPureDeletion
    ? '<span class="empty-code">(pure deletion)</span>'
    : esc(hunk.after) || '<span class="empty-code">(empty)</span>';

  html += \`<div class="diff-columns">
    <div class="diff-col diff-col-before">
      <div class="diff-col-label label-before">− before</div>
      <div class="diff-pre-wrap"><pre class="diff-pre bg-before">\${beforeContent}</pre></div>
    </div>
    <div class="diff-col diff-col-after">
      <div class="diff-col-label label-after">+ after</div>
      <div class="diff-pre-wrap"><pre class="diff-pre bg-after">\${afterContent}</pre></div>
    </div>
  </div>\`;

  html += \`<div>
    <div class="comment-label">comment for this hunk</div>
    <textarea class="comment\${cur.trim() ? ' has-value' : ''}"
      id="comment-input"
      placeholder="Leave a comment for the AI to address…">\${esc(cur)}</textarea>
  </div>\`;

  panel.innerHTML = html;

  document.getElementById('btn-prev').addEventListener('click', () => { state.hunk--; renderAll(); });
  document.getElementById('btn-next').addEventListener('click', () => { state.hunk++; renderAll(); });

  const ta = document.getElementById('comment-input');
  ta.addEventListener('input', () => {
    state.comments[k] = ta.value;
    ta.classList.toggle('has-value', !!ta.value.trim());
    updateSubmitBtn();
    renderFileList();
  });
  ta.focus();
}

// ── Submit button ──────────────────────────────────────────────────────────
function updateSubmitBtn() {
  const n = totalComments();
  document.getElementById('comment-summary').textContent =
    n ? \`\${n} comment\${n !== 1 ? 's' : ''}\` : '';
}

function renderAll() { renderFileList(); renderDiffPanel(); updateSubmitBtn(); }

// ── Submit ─────────────────────────────────────────────────────────────────
document.getElementById('submit-btn').addEventListener('click', async () => {
  const btn = document.getElementById('submit-btn');
  btn.disabled = true;
  btn.textContent = 'submitting…';
  try {
    const res = await fetch('/submit', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ comments: state.comments }),
    });
    if (res.ok) {
      document.getElementById('done-overlay').classList.add('visible');
      setTimeout(() => window.open('', '_self').close(), 1000);
    } else {
      throw new Error(\`HTTP \${res.status}\`);
    }
  } catch (e) {
    btn.disabled = false;
    btn.textContent = 'Submit';
    alert('Submission failed: ' + e.message);
  }
});

// ── Keyboard shortcuts ─────────────────────────────────────────────────────
document.addEventListener('keydown', e => {
  const isCmd = e.metaKey || e.ctrlKey;

  if (isCmd && e.key === 'Enter') {
    e.preventDefault();
    document.getElementById('submit-btn').click();
    return;
  }

  if (isCmd && ['ArrowLeft','ArrowRight','ArrowUp','ArrowDown'].includes(e.key)) {
    e.preventDefault();
    const f = FILES[state.file];
    if (!f) return;
    if      (e.key === 'ArrowRight' && state.hunk < f.hunks.length - 1) { state.hunk++;                  renderAll(); }
    else if (e.key === 'ArrowLeft'  && state.hunk > 0)                  { state.hunk--;                  renderAll(); }
    else if (e.key === 'ArrowDown'  && state.file < FILES.length - 1)   { state.file++; state.hunk = 0; renderAll(); }
    else if (e.key === 'ArrowUp'    && state.file > 0)                  { state.file--; state.hunk = 0; renderAll(); }
  }
});

renderAll();
</script>
</body>
</html>`;


// ── HTTP Server ───────────────────────────────────────────────────────────────

function openBrowser(url) {
  try {
    if (platform() === 'darwin')     execFileSync('open', [url]);
    else if (platform() === 'win32') execFileSync('cmd', ['/c', 'start', '', url]);
    else                             execFileSync('xdg-open', [url]);
  } catch { /* ignore */ }
}

function findFreePort() {
  return new Promise((resolve, reject) => {
    const srv = require('net').createServer();
    srv.listen(0, '127.0.0.1', () => {
      const port = srv.address().port;
      srv.close(() => resolve(port));
    });
    srv.on('error', reject);
  });
}

function startServer(html, port) {
  let resolveSubmit;
  const submitted = new Promise(r => { resolveSubmit = r; });

  const server = http.createServer((req, res) => {
    if (req.method === 'GET' && req.url === '/') {
      const body = Buffer.from(html, 'utf8');
      res.writeHead(200, { 'Content-Type': 'text/html; charset=utf-8', 'Content-Length': body.length });
      res.end(body);

    } else if (req.method === 'POST' && req.url === '/submit') {
      let raw = '';
      req.on('data', chunk => { raw += chunk; });
      req.on('end', () => {
        const { comments } = JSON.parse(raw);
        res.writeHead(200, { 'Content-Type': 'text/plain' });
        res.end('ok');
        // Resolve after the response is fully flushed
        setImmediate(() => resolveSubmit(comments));
      });

    } else {
      res.writeHead(404);
      res.end();
    }
  });

  server.listen(port, '127.0.0.1');
  return { server, submitted };
}


// ── Main ──────────────────────────────────────────────────────────────────────

async function main() {
  const args = process.argv.slice(2);

  if (args[0] === 'install') {
    installSlashCommand();
    process.exit(0);
  }

  ensureSlashCommand();
  const diffArgs = args.length ? args : ['HEAD'];

  let diffText;
  try {
    diffText = execFileSync('git', ['diff', ...diffArgs], { encoding: 'utf8' });
  } catch (e) {
    process.stderr.write(`git diff failed:\n${e.stderr || e.message}\n`);
    process.exit(1);
  }

  if (!diffText.trim()) {
    process.stderr.write('No changes found.\n');
    process.exit(0);
  }

  const files = parseDiff(diffText);
  if (!files.length) {
    process.stderr.write('No parseable changes found (binary-only diff?).\n');
    process.exit(0);
  }

  const html = HTML.replace('__DIFF_DATA__', JSON.stringify(files));
  const port = await findFreePort();
  const url  = `http://127.0.0.1:${port}`;

  const { server, submitted } = startServer(html, port);

  const totalHunks = files.reduce((n, f) => n + f.hunks.length, 0);
  process.stderr.write(`  Reviewing ${files.length} file(s), ${totalHunks} hunk(s) → ${url}\n`);
  openBrowser(url);

  const comments = await submitted;
  server.close();

  const prompt = buildPrompt(files, comments);
  if (prompt) process.stdout.write(prompt + '\n');
}

main().catch(e => { process.stderr.write(e.message + '\n'); process.exit(1); });
